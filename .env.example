# Copiar este archivo como .env para desarrollo local (en Render se configuran como variables de entorno)

# Render provee esta variable automaticamente al conectar tu base PostgreSQL
DATABASE_URL=postgres://usuario:password@localhost:5432/kiosco_pos

# Poner en "true" si tu proveedor de Postgres exige SSL (Render lo exige en produccion)
DATABASE_SSL=true

# Secreto para firmar las cookies de sesion. Generar uno propio y random en produccion.
SESSION_SECRET=cambia-este-secreto-por-uno-largo-y-random

# Puerto en el que corre el servidor (Render inyecta PORT automaticamente)
PORT=3000

# Usuario administrador inicial que se crea la primera vez que se corre la migracion
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Zona horaria del negocio. Afecta como se agrupan ventas por dia en dashboard y reportes.
# Lista completa: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/Argentina/Buenos_Aires

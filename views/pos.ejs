<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('partials/head', { title: 'Aura - Vender' }) %>
</head>
<body>
  <div class="shell">
    <%- include('partials/nav', { active: 'pos' }) %>
    <main class="shell-main pos-main">
      <% if (!session) { %>
        <div class="panel pos-closed">
          <h2>La caja esta cerrada</h2>
          <p class="page-subtitle">Abri la caja con el monto inicial para empezar a vender</p>
          <form action="/caja/abrir" method="POST" class="inline-form">
            <input type="number" step="0.01" name="opening_amount" placeholder="Monto inicial" required>
            <button type="submit" class="btn-primary">Abrir caja</button>
          </form>
        </div>
      <% } else { %>
      <div class="pos-grid">
        <div class="pos-catalog">
          <div class="pos-search">
            <input type="text" id="posSearch" placeholder="Buscar o escanear codigo de barras..." autofocus>
          </div>
          <div class="chip-row" id="categoryChips">
            <button class="chip chip-active" data-category="todas">Todas</button>
            <% categories.forEach(function(c) { %>
              <button class="chip" data-category="<%= c.id %>" style="--chip-color: <%= c.color %>"><%= c.name %></button>
            <% }) %>
          </div>
          <div class="product-grid" id="productGrid">
            <% products.forEach(function(p) { %>
              <button class="product-tile" data-category="<%= p.category_id %>" data-name="<%= p.name.toLowerCase() %>" data-barcode="<%= p.barcode || '' %>"
                data-id="<%= p.id %>" data-price="<%= p.price %>" data-stock="<%= p.stock %>"
                onclick="AuraPOS.addToCart(<%= p.id %>, '<%= p.name.replace(/'/g, "\\'") %>', <%= p.price %>, <%= p.stock %>)">
                <span class="tile-dot" style="background: <%= p.category_color || '#6C5CE7' %>"></span>
                <span class="tile-name"><%= p.name %></span>
                <span class="tile-price">$<%= Number(p.price).toFixed(2) %></span>
                <span class="tile-stock"><%= p.stock %> <%= p.unit %></span>
              </button>
            <% }) %>
          </div>
        </div>

        <div class="pos-cart">
          <h2>Venta actual</h2>
          <div class="cart-items" id="cartItems">
            <p class="empty" id="cartEmpty">Todavia no agregaste productos</p>
          </div>

          <div class="cart-customer">
            <input type="text" id="customerSearch" placeholder="Cliente (opcional)">
            <div id="customerResults" class="autocomplete-results"></div>
            <input type="hidden" id="customerId">
          </div>

          <div class="cart-summary">
            <div class="summary-row"><span>Subtotal</span><span id="cartSubtotal">$0.00</span></div>
            <div class="summary-row">
              <span>Descuento</span>
              <input type="number" id="cartDiscount" min="0" step="0.01" value="0">
            </div>
            <div class="summary-row summary-total"><span>Total</span><span id="cartTotal">$0.00</span></div>
          </div>

          <div class="payment-methods" id="paymentMethods">
            <button class="payment-chip payment-active" data-method="efectivo">Efectivo</button>
            <button class="payment-chip" data-method="tarjeta">Tarjeta</button>
            <button class="payment-chip" data-method="transferencia">Transferencia</button>
          </div>

          <div class="cash-row" id="cashRow">
            <input type="number" id="amountPaid" step="0.01" placeholder="Con cuanto paga">
            <span id="changeDisplay" class="change-display">Vuelto: $0.00</span>
          </div>

          <button class="btn-primary btn-full btn-charge" id="chargeBtn">Cobrar</button>
          <button class="btn-ghost btn-full" id="clearCartBtn">Vaciar carrito</button>
        </div>
      </div>
      <% } %>
    </main>
  </div>

  <div class="toast" id="toast"></div>

  <script src="/js/pos.js"></script>
</body>
</html>

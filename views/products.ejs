<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('partials/head', { title: 'Aura - Productos' }) %>
</head>
<body>
  <div class="shell">
    <%- include('partials/nav', { active: 'productos' }) %>
    <main class="shell-main">
      <header class="page-header">
        <div>
          <h1>Productos</h1>
          <p class="page-subtitle">Tu catalogo completo, precios y stock</p>
        </div>
        <button class="btn-primary" onclick="AuraUI.openModal('newProductModal')">Nuevo producto</button>
      </header>

      <form class="inline-form search-form" method="GET" action="/productos">
        <input type="text" name="q" value="<%= search %>" placeholder="Buscar por nombre o codigo de barras">
        <button type="submit" class="btn-ghost">Buscar</button>
      </form>

      <section class="panel">
        <div class="table-wrap">
          <table>
            <thead>
              <tr><th>Producto</th><th>Categoria</th><th>Precio</th><th>Costo</th><th>Stock</th><th></th></tr>
            </thead>
            <tbody>
              <% products.forEach(function(p) { %>
                <tr>
                  <td><%= p.name %><br><span class="muted"><%= p.barcode || '' %></span></td>
                  <td><span class="pill" style="background: <%= p.category_color %>22; color: <%= p.category_color %>"><%= p.category_name || 'Sin categoria' %></span></td>
                  <td>$<%= Number(p.price).toFixed(2) %></td>
                  <td>$<%= Number(p.cost).toFixed(2) %></td>
                  <td><span class="pill <%= Number(p.stock) <= Number(p.min_stock) ? 'pill-warning' : 'pill-ok' %>"><%= p.stock %> <%= p.unit %></span></td>
                  <td class="row-actions">
                    <button class="link-action" onclick='AuraUI.openEditProduct(<%- JSON.stringify(p) %>)'>Editar</button>
                    <form action="/productos/<%= p.id %>/eliminar" method="POST" class="inline">
                      <button type="submit" class="link-action link-danger">Eliminar</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
              <% if (products.length === 0) { %>
                <tr><td colspan="6" class="empty">No se encontraron productos</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </section>

      <section class="panel">
        <div class="panel-header-row">
          <h2>Categorias</h2>
          <button class="btn-ghost btn-small" onclick="AuraUI.openModal('newCategoryModal')">Nueva categoria</button>
        </div>
        <div class="chip-row">
          <% categories.forEach(function(c) { %>
            <span class="chip" style="--chip-color: <%= c.color %>">
              <%= c.name %>
              <form action="/categorias/<%= c.id %>/eliminar" method="POST" class="inline">
                <button type="submit" class="chip-remove">&times;</button>
              </form>
            </span>
          <% }) %>
        </div>
      </section>
    </main>
  </div>

  <div class="modal" id="newProductModal">
    <div class="modal-card">
      <h2>Nuevo producto</h2>
      <form action="/productos" method="POST" class="modal-form">
        <label>Nombre</label>
        <input type="text" name="name" required>
        <label>Codigo de barras</label>
        <input type="text" name="barcode">
        <label>Categoria</label>
        <select name="category_id">
          <option value="">Sin categoria</option>
          <% categories.forEach(function(c) { %><option value="<%= c.id %>"><%= c.name %></option><% }) %>
        </select>
        <div class="form-row">
          <div><label>Precio de venta</label><input type="number" step="0.01" name="price" required></div>
          <div><label>Costo</label><input type="number" step="0.01" name="cost"></div>
        </div>
        <div class="form-row">
          <div><label>Stock inicial</label><input type="number" step="0.01" name="stock"></div>
          <div><label>Stock minimo</label><input type="number" step="0.01" name="min_stock" value="3"></div>
        </div>
        <label>Unidad</label>
        <input type="text" name="unit" value="unidad">
        <div class="modal-actions">
          <button type="button" class="btn-ghost" onclick="AuraUI.closeModal('newProductModal')">Cancelar</button>
          <button type="submit" class="btn-primary">Guardar</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal" id="editProductModal">
    <div class="modal-card">
      <h2>Editar producto</h2>
      <form id="editProductForm" method="POST" class="modal-form">
        <label>Nombre</label>
        <input type="text" name="name" id="editName" required>
        <label>Codigo de barras</label>
        <input type="text" name="barcode" id="editBarcode">
        <label>Categoria</label>
        <select name="category_id" id="editCategory">
          <option value="">Sin categoria</option>
          <% categories.forEach(function(c) { %><option value="<%= c.id %>"><%= c.name %></option><% }) %>
        </select>
        <div class="form-row">
          <div><label>Precio de venta</label><input type="number" step="0.01" name="price" id="editPrice" required></div>
          <div><label>Costo</label><input type="number" step="0.01" name="cost" id="editCost"></div>
        </div>
        <div class="form-row">
          <div><label>Stock</label><input type="number" step="0.01" name="stock" id="editStock"></div>
          <div><label>Stock minimo</label><input type="number" step="0.01" name="min_stock" id="editMinStock"></div>
        </div>
        <label>Unidad</label>
        <input type="text" name="unit" id="editUnit">
        <div class="modal-actions">
          <button type="button" class="btn-ghost" onclick="AuraUI.closeModal('editProductModal')">Cancelar</button>
          <button type="submit" class="btn-primary">Guardar cambios</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal" id="newCategoryModal">
    <div class="modal-card modal-small">
      <h2>Nueva categoria</h2>
      <form action="/categorias" method="POST" class="modal-form">
        <label>Nombre</label>
        <input type="text" name="name" required>
        <label>Color</label>
        <input type="color" name="color" value="#6C5CE7">
        <div class="modal-actions">
          <button type="button" class="btn-ghost" onclick="AuraUI.closeModal('newCategoryModal')">Cancelar</button>
          <button type="submit" class="btn-primary">Crear</button>
        </div>
      </form>
    </div>
  </div>

  <script src="/js/ui.js"></script>
</body>
</html>
